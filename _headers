/*
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://images.unsplash.com; connect-src 'self'; frame-ancestors 'none';

# Cache busting for assets with query params
/*.css?v=*
  Cache-Control: public, max-age=31536000, immutable

/*.js?v=*
  Cache-Control: public, max-age=31536000, immutable

# Standard assets
/public/*
  Cache-Control: public, max-age=31536000, immutable

# HTML files - always check for updates
/*.html
  Cache-Control: public, max-age=0, must-revalidate
