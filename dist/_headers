/*
  X-Frame-Options: DENY
  X-XSS-Protection: 0
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), usb=(), interest-cohort=(), display-capture=(), document-domain=(), encrypted-media=(), fullscreen=(self), magnetometer=(), gyroscope=(), accelerometer=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://ahmed-moparak.netlify.app; upgrade-insecure-requests
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: unsafe-none
  Cross-Origin-Resource-Policy: same-site
  X-DNS-Prefetch-Control: on
  X-Permitted-Cross-Domain-Policies: none
  X-Download-Options: noopen

# Immutable versioned CSS and JS in root (old pattern kept for compat)
/*.css?v=*
  Cache-Control: public, max-age=31536000, immutable

/*.js?v=*
  Cache-Control: public, max-age=31536000, immutable

# Versioned compiled assets in public/ (very long cache)
/public/*.css?v=*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/public/*.js?v=*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Lucide (local copy, rarely changes — 30 day cache)
/public/lucide.min.js
  Cache-Control: public, max-age=2592000, immutable
  X-Content-Type-Options: nosniff

# Static public assets (images)
/public/*
  Cache-Control: public, max-age=2592000, immutable
  X-Content-Type-Options: nosniff

# Favicons
/favicon*
  Cache-Control: public, max-age=604800

# HTML — always revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Service worker scope
/
  Cache-Control: public, max-age=0, must-revalidate
